# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native builds
ios/
android/

# env files
.env
.env.local
.env.*.local

# secrets / credentials
credentials/
*.pem
*.key
# Firebase Admin SDK service account key — server secret, never commit.
# (Public client identifiers like google-services.json / GoogleService-Info.plist
# ARE committed because EAS Build only uploads git-tracked files and Firebase
# permissions are enforced server-side via Security Rules, not by hiding the
# client config.)
*-firebase-adminsdk-*.json

# Google Play Store API service account JSON (for `eas submit`). Granted
# Play-Developer permissions, so leaking it lets attackers push builds and
# change store listings — never commit.
play-service-account*.json
google-play-service-account*.json

# IDE / tooling
.vscode/
.idea/
.claude/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# workspace (build pipeline artifacts)
_workspace/

# npm
npm-debug.log*

# Metro
.metro-health-check*
