{
  "expo": {
    "name": "haru",
    "slug": "voicemate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "haruvoice",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/0058361e-081e-4790-b8f9-bf1b4d1e745d"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "backgroundColor": "#FEEEF0",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FEEEF0"
    },
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "#00000000",
      "barStyle": "dark-content"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haruvoice.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8D2DC"
      },
      "package": "com.haruvoice.app",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "haru needs access to your photos so you can choose pictures for your dating profile."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "haru needs access to your photo library to manage your profile photos.",
          "savePhotosPermission": "haru saves a photo to your library only when you choose to download it.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "haru uses your microphone to record your voice profile and to send voice messages in chat."
        }
      ],
      "expo-asset",
      [
        "expo-notifications",
        {
          "color": "#6C5CE7"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.781449315272-s14jdh63094i1nu46slt2cid3p08blj8"
        }
      ],
      "./plugins/withRemoveMediaPermissions.js",
      [
        "@sentry/react-native",
        {
          "organization": "sejin-2s",
          "project": "haru-mobile",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0058361e-081e-4790-b8f9-bf1b4d1e745d"
      }
    }
  }
}
