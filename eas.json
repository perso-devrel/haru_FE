{
    "cli": {
        "version": ">= 18.11.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development",
            "environment": "development",
            "credentialsSource": "local",
            "ios": {
                "credentialsSource": "remote"
            },
            "env": {
                "APP_VARIANT": "development"
            }
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "environment": "preview",
            "android": {
                "buildType": "apk"
            },
            "credentialsSource": "local",
            "ios": {
                "credentialsSource": "remote"
            },
            "env": {
                "APP_VARIANT": "development"
            }
        },
        "production": {
            "autoIncrement": true,
            "channel": "production",
            "environment": "production",
            "credentialsSource": "remote",
            "env": {
                "APP_VARIANT": "production"
            },
            "android": {
                "buildType": "app-bundle"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "internal"
            },
            "ios": {
                "appleId": "sejinim02@gmail.com",
                "ascAppId": "6779128759",
                "appleTeamId": "8Y3T679M89"
            }
        }
    }
}
